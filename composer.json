{
    "name": "detain/phlex-server",
    "type": "project",
    "license": "proprietary",
    "version": "1.0.0",
    "repositories": [
        {
            "type": "vcs",
            "url": "git@github.com:detain/phlex-shared.git"
        }
    ],
    "require": {
        "php": ">=8.3",
        "ext-ldap": "*",
        "crell/tukio": "^2.0",
        "detain/phlex-shared": "^0.3.0",
        "directorytree/ldaprecord": "^3.0",
        "justinrainbow/json-schema": "^5.2",
        "monolog/monolog": "^3.0",
        "php-di/php-di": "^7.0",
        "phpseclib/phpseclib": "^3.0",
        "psr/container": "^2.0",
        "psr/event-dispatcher": "^1.0",
        "smarty/smarty": "^4.0",
        "symfony/process": "^7.0",
        "symfony/yaml": "^7.0",
        "web-auth/webauthn-lib": "^4.0",
        "web-token/jwt-framework": "^3.0",
        "workerman/mysql": "^1.0",
        "workerman/redis": "^2.0",
        "workerman/webman-framework": "^2.0",
        "workerman/workerman": "^5.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "Phlex\\": "src/"
        },
        "files": [
            "src/Plugins/AliasCompatShim.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Phlex\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "extra": {
        "phlex": {
            "minHubVersion": "1.0.0",
            "maxHubVersion": "1.9.9",
            "minPhpVersion": "8.3"
        }
    }
}
