[Unit]
Description=Phlix Media Server Backup Service
Documentation=https://docs.phlix.media
After=phlix-server.service

[Service]
Type=oneshot
User=phlix
Group=phlix
WorkingDirectory=/var/www/phlix
ExecStart=/usr/bin/php /var/www/phlix/scripts/backup.php
StandardOutput=journal
StandardError=journal
SyslogIdentifier=phlix-backup

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/phlix/backups /var/phlix/config /var/phlix/data
